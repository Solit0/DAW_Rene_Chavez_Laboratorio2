@model controlCalidad.Models.InspeccionCalidad
@{ 
    ViewData["Title"] = "Editar Inspección"; 
}

<h2>Editar Inspección @Model.NumeroInspeccion</h2>

<form asp-action="Edit" class="mt-4">
    <input type="hidden" asp-for="Id" />
    
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="NumeroInspeccion" class="form-label"></label>
            <input asp-for="NumeroInspeccion" class="form-control" />
            <span asp-validation-for="NumeroInspeccion" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="Lote" class="form-label"></label>
            <input asp-for="Lote" class="form-control" />
            <span asp-validation-for="Lote" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="Producto" class="form-label"></label>
            <select asp-for="Producto" class="form-select" asp-items="ViewBag.Productos"></select>
            <span asp-validation-for="Producto" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="Inspector" class="form-label"></label>
            <select asp-for="Inspector" class="form-select" asp-items="ViewBag.Inspectores"></select>
            <span asp-validation-for="Inspector" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="CantidadesInspeccionadas" class="form-label"></label>
            <input asp-for="CantidadesInspeccionadas" class="form-control" type="number" />
            <span asp-validation-for="CantidadesInspeccionadas" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="CantidadesDefectuosas" class="form-label"></label>
            <input asp-for="CantidadesDefectuosas" class="form-control" type="number" />
            <span asp-validation-for="CantidadesDefectuosas" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="Resultado" class="form-label"></label>
            <select asp-for="Resultado" class="form-select" asp-items="ViewBag.Resultados"></select>
            <small class="text-muted">Si los defectos superan el 5%, el controlador lo forzará a Rechazado.</small>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="Defecto" class="form-label"></label>
            <select asp-for="Defecto" class="form-select" asp-items="ViewBag.TiposDefecto"></select>
            <span asp-validation-for="Defecto" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}