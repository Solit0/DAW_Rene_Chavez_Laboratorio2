@model controlCalidad.Models.InspeccionCalidad
@{ ViewData["Title"] = "Eliminar"; }

<h3 class="text-danger">¿Estás seguro que deseas eliminar esta inspección rechazada?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Código</dt><dd class="col-sm-10">@Model.NumeroInspeccion</dd>
        <dt class="col-sm-2">Producto</dt><dd class="col-sm-10">@Model.Producto</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>